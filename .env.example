# Copy this file to .env and fill in your values
# DATABASE_URL uses asyncpg driver — required for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://bookuser:bookpass@db:5432/bookdb
TEST_DATABASE_URL=postgresql+asyncpg://bookuser:bookpass@localhost:5432/bookdb_test


# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30